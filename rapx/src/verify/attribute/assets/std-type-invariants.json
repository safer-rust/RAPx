{
  "&[T]": {
    "comment": "Slice reference — the internal pointer is ValidPtr for len(self) elements",
    "invariants": [
      {"tag": "ValidPtr", "args": ["$ptr", "$elem_ty", "$len"]},
      {"tag": "NonNull", "args": ["$ptr"]}
    ]
  },
  "&mut [T]": {
    "comment": "Mutable slice reference",
    "invariants": [
      {"tag": "ValidPtr", "args": ["$ptr", "$elem_ty", "$len"]},
      {"tag": "NonNull", "args": ["$ptr"]},
      {"tag": "Init", "args": ["$ptr", "$elem_ty", "$len"]}
    ]
  },
  "core::num::NonZero<T>": {
    "comment": "NonZero integer — inner value must be non-zero",
    "invariants": [
      {"tag": "ValidNum", "args": ["$self != 0"]}
    ]
  },
  "core::num::nonzero::NonZero<T>": {
    "comment": "NonZero integer (full path) — inner value must be non-zero",
    "invariants": [
      {"tag": "ValidNum", "args": ["$self != 0"]}
    ]
  },
  "std::num::NonZero<T>": {
    "comment": "NonZero integer (std path) — inner value must be non-zero",
    "invariants": [
      {"tag": "ValidNum", "args": ["$self != 0"]}
    ]
  },
  "alloc::boxed::Box<T>": {
    "comment": "Box<T> — the internal pointer is non-null and aligned for one element",
    "invariants": [
      {"tag": "NonNull", "args": ["0"]},
      {"tag": "Align", "args": ["0", "T"]}
    ]
  },
  "std::boxed::Box<T>": {
    "comment": "Box<T> (std path)",
    "invariants": [
      {"tag": "NonNull", "args": ["0"]},
      {"tag": "Align", "args": ["0", "T"]}
    ]
  },
  "alloc::vec::Vec<T>": {
    "comment": "Vec<T> — pointer field is non-null and aligned for T",
    "invariants": [
      {"tag": "NonNull", "args": ["0.0"]},
      {"tag": "Align", "args": ["0.0", "T"]}
    ]
  },
  "std::vec::Vec<T>": {
    "comment": "Vec<T> (std path)",
    "invariants": [
      {"tag": "NonNull", "args": ["0.0"]},
      {"tag": "Align", "args": ["0.0", "T"]}
    ]
  }
}
